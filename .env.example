# ─────────────────────────────────────────────────────────────────────────────
# The Round Table — environment configuration
# Copy this file to `.env` (NEVER commit `.env`) and fill in the real values.
# Every key below is required for the app to run end-to-end.
# ─────────────────────────────────────────────────────────────────────────────

# Environment marker (dev | preview | production)
EXPO_PUBLIC_ENV=dev

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get from https://supabase.com/dashboard → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Server-side ONLY (Edge Functions, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ─── RevenueCat (entitlements + IAP orchestration) ───────────────────────────
# Get from https://app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_RC_IOS_API_KEY=appl_XXX
EXPO_PUBLIC_RC_ANDROID_API_KEY=goog_XXX
# Web uses RC's web billing or your own Stripe — pick one. We use Stripe via RC.
EXPO_PUBLIC_RC_STRIPE_API_KEY=strp_XXX
REVENUECAT_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET

# Entitlement identifiers configured in RevenueCat dashboard:
#   new_member · knight · council
EXPO_PUBLIC_RC_ENTITLEMENT_NEW_MEMBER=new_member
EXPO_PUBLIC_RC_ENTITLEMENT_KNIGHT=knight
EXPO_PUBLIC_RC_ENTITLEMENT_COUNCIL=council

# ─── Stripe (web subscriptions, via RevenueCat web billing) ──────────────────
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXX
STRIPE_SECRET_KEY=sk_test_XXX
STRIPE_WEBHOOK_SECRET=whsec_XXX

# ─── Google Sign-In ──────────────────────────────────────────────────────────
# Web OAuth client + iOS OAuth client from Google Cloud Console
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=XXX.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=XXX.apps.googleusercontent.com

# ─── Mux (signed video playback for paid content) ────────────────────────────
MUX_TOKEN_ID=YOUR_TOKEN_ID
MUX_TOKEN_SECRET=YOUR_TOKEN_SECRET
MUX_SIGNING_KEY_ID=YOUR_SIGNING_KEY_ID
MUX_SIGNING_KEY_PRIVATE=YOUR_PRIVATE_KEY_PEM

# ─── Resend (transactional email) ────────────────────────────────────────────
RESEND_API_KEY=re_XXX
RESEND_FROM_EMAIL="The Round Table <noreply@roundtable.app>"

# ─── Sentry (crash + error reporting) ────────────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=https://XXX@sentry.io/XXX
SENTRY_AUTH_TOKEN=XXX
SENTRY_ORG=XXX
SENTRY_PROJECT=XXX

# ─── PostHog (product analytics) ─────────────────────────────────────────────
EXPO_PUBLIC_POSTHOG_API_KEY=phc_XXX
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Anthropic Claude (AI features, server-side only) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXX
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Site URLs ───────────────────────────────────────────────────────────────
EXPO_PUBLIC_APP_URL=https://roundtable.app
EXPO_PUBLIC_MARKETING_URL=https://roundtable.app
EXPO_PUBLIC_SUPPORT_EMAIL=support@roundtable.app
